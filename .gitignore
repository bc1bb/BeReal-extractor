# ---------------------------------------------------------------
# bereal-archive .gitignore
#
# Block ANY chance of personal data being committed. This tool is
# meant to be used inside a BeReal export folder, so we also block
# the export artefacts in case someone places this scripts folder
# alongside their data and then `git init`s the parent.
# ---------------------------------------------------------------

# BeReal export artefacts (data the tool consumes)
/Photos/
/conversations/
/*.json
/*.zip

# Analysis artefacts generated locally (regenerated by the scripts)
/cache.json
/faces.json
/faces_raw.npz
/people_labels.json

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version

# Logs and temp output
*.log
*.tmp

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
